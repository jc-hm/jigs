{
  "name": "@jigs/cdk",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "build": "tsc",
    "synth": "cdk synth",
    "deploy:staging": "cdk deploy --context stage=staging --require-approval never",
    "deploy:prod": "cdk deploy --context stage=prod --require-approval never",
    "diff:staging": "cdk diff --context stage=staging",
    "diff:prod": "cdk diff --context stage=prod",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.180.0",
    "constructs": "^10.4.0"
  },
  "devDependencies": {
    "aws-cdk": "^2.180.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
